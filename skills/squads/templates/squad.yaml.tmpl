# Squad Manifest — generated by Squad Protocol Engine v4.0.0
# Source of truth: SQUAD_PROTOCOL.md Section 4.1

name: "{{SQUAD_NAME}}"
version: "1.0.0"
short-title: "{{SHORT_TITLE}}"
description: "{{DESCRIPTION}}"
author: "{{AUTHOR}}"
license: MIT
slashPrefix: "{{PREFIX}}"

runtime:
  minVersion: "4.0.0"
  type: squad

tags:
  - "{{TAG_1}}"
  - "{{TAG_2}}"

components:
  # Task-first: tasks are the primary unit of work
  tasks:
    - "{{task-name}}.md"
  agents:
    - "{{agent-id}}.yaml"
  workflows:
    - "{{workflow-name}}.yaml"
  checklists: []
  templates: []
  tools: []
  scripts: []

config:
  extends: none

state:
  enabled: true
  storage: file
  checkpoint_dir: ".squad-state"
  resume: true

model_strategy:
  orchestrator: "claude-sonnet-4"
  workers: "claude-sonnet-4"
  reviewers: "claude-sonnet-4"
  override: true

harness:
  doom_loop:
    enabled: true
    max_identical_outputs: 3
    similarity_threshold: 0.95
    on_detect: change-strategy

  ralph_loop:
    enabled: true
    max_iterations: 5
    persist_state: true

  context_compaction:
    enabled: true
    strategy: key-fields
    max_handoff_tokens: 4000
    preserve_schema_fields: true

  filesystem_collaboration:
    enabled: true
    artifact_dir: ".artifacts/{{SQUAD_NAME}}"
    cleanup: manual

  traces:
    enabled: true
    level: standard
    include_outputs: false

  self_verify:
    default_enabled: true

  quality_framework:
    enabled: true
    threshold: 7.0
    dimensions:
      accuracy: { weight: 1.0, threshold: 7.0, veto: true }
      coherence: { weight: 0.9, threshold: 7.0, veto: false }

dependencies:
  node: []
  python: []
  squads: []
